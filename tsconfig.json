{
  "compilerOptions": {
    "target": "es2021",
    "strict": true,
    "module": "commonjs",
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowUnusedLabels": true, 
    "allowUnreachableCode": true, 
    "sourceMap": true,
    "allowJs": true,
    "lib": [
      "es7",
      "dom"
    ],
    "rootDir": "src",
    "moduleResolution": "node"
  }
}